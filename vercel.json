{
  "rewrites": [
    { "source": "/((?!assets|sw\\.js|workbox-|manifest\\.json|robots\\.txt|favicon\\.ico|pwa-).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
